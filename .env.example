# EmailJS Configuration
# Create your EmailJS account at https://www.emailjs.com/
# Copy these values from your EmailJS dashboard

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_USER_ID=your_user_id_here

# Mistral AI (chatbot) : AUCUNE variable ici.
# La clé vit côté serveur uniquement : fichier mistral-key.php placé dans le
# dossier du domaine sur Hostinger (HORS de public_html), lu par public/api/chat.php.
# Contenu du fichier :  <?php return 'VOTRE_CLE'; ?>
# Voir docs/mistral-ai-setup.md. Jamais de secret dans une variable VITE_*.

# Google Tag Manager est configuré directement dans index.html
