# EmailJS Configuration
# Create your EmailJS account at https://www.emailjs.com/
# Copy these values from your EmailJS dashboard

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_USER_ID=your_user_id_here

# Mistral AI Configuration (chatbot)
# Get your API key at https://console.mistral.ai/
# WARNING: this key is exposed in the client bundle. Use rate limits
# and budget caps on the Mistral console to prevent abuse.
VITE_MISTRAL_API_KEY=your_mistral_api_key_here

# Google Tag Manager est configuré directement dans index.html
# ID GTM : GTM-KLGC32HC
# Configurez vos tags dans Google Tag Manager : https://tagmanager.google.com/

# Optional: Add other environment variables here
# VITE_SITE_URL=https://your-domain.com